{
  "version": 2,
  "builds": [
    { "src": "public/index.php", "use": "vercel-php@0.6.0" },
    { "src": "public/build/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}